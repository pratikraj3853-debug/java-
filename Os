#!/bin/bash

sum=0

echo "Non-directory files in current directory:"

for file in *
do
    if [ -f "$file" ]
    then
        echo "$file"

        size=$(wc -c < "$file")
        sum=$((sum + size))
    fi
done

echo "Total size of all non-directory files = $sum bytes"

