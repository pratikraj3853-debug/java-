#!/bin/bash

child_process() {
    for i in {1..10}
    do
        echo "Number: $i | PID: $$ | PPID: $PPID"
        sleep 1
    done
}

child_process &
pid1=$!

child_process &
pid2=$!

wait $pid1
wait $pid2

echo "Good Bye"

