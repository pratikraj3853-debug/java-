#!/bin/bash

global=10

function test()
{
    local localvar=20

    (
        global=$((global + 1))
        localvar=$((localvar + 1))

        echo "Child Process:"
        echo "Global = $global"
        echo "Local = $localvar"
    )

    echo "Parent Process:"
    echo "Global = $global"
    echo "Local = $localvar"
}

test

