4) Local and global variable with child process

#include <stdio.h>
#include <unistd.h>

int global = 10;

int main()
{
    int local = 20;

    pid_t pid;

    pid = fork();

    if(pid < 0)
    {
        printf("Fork failed\n");
    }
    else if(pid == 0)
    {
        global++;
        local++;

        printf("\nChild Process\n");
        printf("Global = %d\n", global);
        printf("Local = %d\n", local);
    }
    else
    {
        sleep(1);

        printf("\nParent Process\n");
        printf("Global = %d\n", global);
        printf("Local = %d\n", local);
    }

    return 0;
}


