5) Background process for 50 seconds and print system information

#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

int main()
{
    pid_t pid;

    pid = fork();

    if(pid < 0)
    {
        printf("Fork failed\n");
    }
    else if(pid > 0)
    {
        printf("Background process started\n");
        exit(0);
    }
    else
    {
        setsid();

        sleep(50);

        printf("\nSystem Information:\n");

        system("uname -a");
    }

    return 0;
}


