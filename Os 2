8) Create 3 child processes executing commands

Child 1 → who

Child 2 → ls -l

Child 3 → date


#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>

int main()
{
    pid_t p1, p2, p3;
    int status;

    // First Child
    p1 = fork();

    if(p1 == 0)
    {
        printf("\nFirst Child executing 'who'\n");
        execlp("who", "who", NULL);
        exit(0);
    }

    // Second Child
    p2 = fork();

    if(p2 == 0)
    {
        printf("\nSecond Child executing 'ls -l'\n");
        execlp("ls", "ls", "-l", NULL);
        exit(0);
    }

    // Third Child
    p3 = fork();

    if(p3 == 0)
    {
        printf("\nThird Child executing 'date'\n");
        execlp("date", "date", NULL);
        exit(0);
    }

    // Parent waits
    wait(&status);
    printf("One child terminated\n");

    wait(&status);
    printf("Second child terminated\n");

    wait(&status);
    printf("Third child terminated\n");

    return 0;
}
