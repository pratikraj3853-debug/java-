7) Create 2 child processes

#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>

int main()
{
    pid_t p1, p2;
    int i;

    p1 = fork();

    if(p1 == 0)
    {
        for(i = 1; i <= 10; i++)
        {
            printf("Child 1 : %d  PID=%d  ParentPID=%d\n",
                   i, getpid(), getppid());
        }
        exit(0);
    }

    p2 = fork();

    if(p2 == 0)
    {
        for(i = 1; i <= 10; i++)
        {
            printf("Child 2 : %d  PID=%d  ParentPID=%d\n",
                   i, getpid(), getppid());
        }
        exit(0);
    }

    wait(NULL);
    wait(NULL);

    printf("\nGood Bye\n");

    return 0;
}


