package MathPack;

public class MathOperations {

    public static int absolute(int n) {
        if (n < 0)
            return -n;
        else
            return n;
    }

    public static double power(double a, double b) {
        return Math.pow(a, b);
    }

    public static double squareRoot(double n) {
        return Math.sqrt(n);
    }

    public static double cubeRoot(double n) {
        return Math.cbrt(n);
    }
}



Main Program

  import java.util.Scanner;
import MathPack.MathOperations;

public class DemoMath {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int choice;

        do {
            System.out.println("\n--- Mathematical Operations ---");
            System.out.println("1. Absolute Value");
            System.out.println("2. Power");
            System.out.println("3. Square Root");
            System.out.println("4. Cube Root");
            System.out.println("5. Exit");

            System.out.print("Enter your choice: ");
            choice = sc.nextInt();

            switch(choice) {

                case 1:
                    System.out.print("Enter integer: ");
                    int n = sc.nextInt();

                    System.out.println("Absolute Value = "
                            + MathOperations.absolute(n));
                    break;

                case 2:
                    System.out.print("Enter base: ");
                    double a = sc.nextDouble();

                    System.out.print("Enter exponent: ");
                    double b = sc.nextDouble();

                    System.out.println("Power = "
                            + MathOperations.power(a, b));
                    break;

                case 3:
                    System.out.print("Enter number: ");
                    double s = sc.nextDouble();

                    System.out.println("Square Root = "
                            + MathOperations.squareRoot(s));
                    break;

                case 4:
                    System.out.print("Enter number: ");
                    double c = sc.nextDouble();

                    System.out.println("Cube Root = "
                            + MathOperations.cubeRoot(c));
                    break;

                case 5:
                    System.out.println("Program Ended");
                    break;

                default:
                    System.out.println("Invalid Choice");
            }

        } while(choice != 5);

        sc.close();
    }
}
