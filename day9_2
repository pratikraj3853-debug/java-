import java.io.*;

public class Filecopy {

    public static void main(String[] args) {

        String sourceFile = "source.txt";
        String destinationFile = "destination.txt";

        try {

            FileWriter fw = new FileWriter(sourceFile);

            fw.write("This is line 1\n");
            fw.write("This is line 2\n");
            fw.write("This is line 3\n");
            fw.write("This is line 4\n");
            fw.write("This is line 5\n");

            fw.close();

            FileReader fr = new FileReader(sourceFile);
            FileWriter fw2 = new FileWriter(destinationFile);

            int ch;

            while((ch = fr.read()) != -1) {
                fw2.write(ch);
            }

            fr.close();
            fw2.close();

            BufferedReader br =
                    new BufferedReader(
                            new FileReader(destinationFile));

            String line;

            System.out.println(
                    "\nContents of destination file:\n");

            while((line = br.readLine()) != null) {
                System.out.println(line);
            }

            br.close();

        } catch(IOException e) {

            System.out.println(e);
        }
    }
}
